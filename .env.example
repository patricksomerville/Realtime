# Required
OPENAI_API_KEY=sk-your-key-here

# Optional: ElevenLabs TTS (for speak.py)
ELEVENLABS_API_KEY=your-elevenlabs-key-here

# Optional: Microphone selection
# VOICE_INPUT_DEVICE=0
# VOICE_INPUT_GAIN=2.0
# VOICE_VAD_THRESHOLD=0.18
# VOICE_ALLOW_OUTPUT_INPUT=0

# Optional: Local LLM command parsing
# VOICE_USE_LOCAL_LLM_COMMANDS=1
# VOICE_LOCAL_LLM_URL=http://localhost:11434/v1/chat/completions
# VOICE_LOCAL_LLM_MODEL=qwen2.5-coder:3b
# VOICE_EXECUTE_LLM_COMMANDS=0

# Optional: TTS engine for viewer ack sounds
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=alloy
# ORPHEUS_TTS_URL=
